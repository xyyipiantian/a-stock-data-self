{
  "localPort": 8787,
  "localHost": "127.0.0.1",
  "localBasePath": "/anthropic",
  "upstream": {
    "baseUrl": "https://token-plan-sgp.xiaomimimo.com/anthropic",
    "authToken": "replace-with-your-upstream-token",
    "textModel": "mimo-v2.5-pro",
    "visionModel": "mimo-v2-omni",
    "visionCapableModels": [
      "mimo-v2-omni"
    ],
    "timeoutMs": 120000
  },
  "preprocessing": {
    "enabled": true,
    "injectMode": "replace-image-blocks",
    "visionPrompt": "你是一个图片转文本预处理器。请读取用户上传的图片，并输出适合继续交给纯文本模型的结构化摘要。请优先提取：1. 图片类型和整体场景 2. 画面中的关键文字（OCR） 3. 关键 UI、报错、表格、代码、图表或对象 4. 与用户问题最相关的线索。输出使用中文，简洁但信息完整，不要臆测无法确定的内容。"
  }
}
